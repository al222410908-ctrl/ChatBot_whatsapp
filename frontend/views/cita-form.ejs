<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= cita ? 'Editar Cita' : 'Nueva Cita' %> - Citas Médicas</title>
    <meta name="description" content="Formulario para agendar o editar una cita médica">
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Estilos compartidos -->
        <link rel="stylesheet" href="/css/app.css">
        <script src="/js/mobile-toggle.js" defer></script>
    <script>
        (function() {
            const t = localStorage.getItem('theme');
            if (t === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
            const c = localStorage.getItem('color-theme') || 'clinico';
            document.documentElement.setAttribute('data-color-theme', c);
        })();
    </script>
</head>
<body>
    

    <div class="container-fluid">
        <div class="row flex-nowrap">
            <!-- Sidebar Navigation -->
            <div class="col-md-2 sidebar p-0 d-flex flex-column d-none d-md-flex">
                <div class="p-4 brand-title d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-hospital fs-4" style="color:#818cf8"></i>
                    <span class="fs-5">Citas Médicas</span>
                </div>
                <nav class="nav flex-column">
                    <a class="nav-link" href="/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                    <a class="nav-link active" href="/citas"><i class="bi bi-calendar3"></i> Citas</a>
                    <a class="nav-link" href="/pacientes"><i class="bi bi-people-fill"></i> Pacientes</a>
                    <a class="nav-link" href="/mensajes"><i class="bi bi-chat-left-dots-fill"></i> Mensajes</a>
                    <a class="nav-link" href="/chat"><i class="bi bi-chat-dots-fill"></i> Chat en Vivo <span class="badge-dot ms-auto" id="unread-dot" style="display:none"></span></a>
                    <a class="nav-link" href="/analytics"><i class="bi bi-bar-chart-line-fill"></i> Analytics</a>
                    <a class="nav-link" href="/configuracion"><i class="bi bi-gear-fill"></i> Configuración</a>
                </nav>

                <!-- WhatsApp Status Widget -->
                <div class="wa-status-widget mx-2 mt-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="wa-dot off" id="ws-status-icon"></span>
                        <span class="fw-semibold small text-main">WhatsApp Bot</span>
                    </div>
                    <div id="ws-status-text" class="small text-muted">Consultando...</div>
                    <div id="ws-qr-container" class="mt-2 text-center d-none">
                        <img id="ws-qr-img" src="" alt="Escanee QR" class="img-fluid rounded" style="max-height:120px">
                        <div class="small mt-1 text-warning">📱 Escanee para conectar</div>
                    </div>
                    <button onclick="reconectarWA()" class="btn btn-sm w-100 mt-2">
                        <i class="bi bi-arrow-repeat me-1"></i>Reconectar
                    </button>
                </div>

                <div class="px-3 py-2 mt-auto mb-2">
                    <button class="btn-sidebar-action mb-2 animate-hover" onclick="toggleDark()" id="dark-toggle-btn">
                        <i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro
                    </button>
                    <a href="/logout" class="btn-sidebar-action btn-sidebar-danger animate-hover">
                        <i class="bi bi-box-arrow-left"></i> Cerrar Sesión
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 main-content">

                <div class="page-header">
                    <div>
                        <h2><%= cita ? 'Editar Cita' : 'Nueva Cita Médica' %></h2>
                        <p>Rellena los datos para programar y agendar la cita en el sistema</p>
                    </div>
                    <a href="/citas" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                </div>

                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-calendar-plus text-primary me-2"></i>
                                <%= cita ? 'Editar datos de la cita' : 'Datos de la nueva cita' %>
                            </div>
                            <div class="card-body p-4">
                                <form action="<%= cita ? '/citas/' + cita.id + '/editar' : '/citas/nueva' %>" method="POST">
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <label for="paciente_id" class="form-label fw-semibold">Paciente</label>
                                            <select class="form-select" id="paciente_id" name="paciente_id" required>
                                                <option value="">Seleccionar paciente...</option>
                                                <% pacientes.forEach(paciente => { %>
                                                    <option value="<%= paciente.id %>" <%= cita && cita.paciente_id === paciente.id ? 'selected' : '' %>>
                                                        <%= paciente.nombre %> (<%= paciente.telefono %>)
                                                    </option>
                                                <% }); %>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="fecha" class="form-label fw-semibold">Fecha de Consulta</label>
                                            <input type="date" class="form-control" id="fecha" name="fecha"
                                                   value="<%= cita ? cita.fecha : '' %>" required>
                                        </div>
                                    </div>

                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <label for="hora" class="form-label fw-semibold">Hora de Consulta</label>
                                            <input type="time" class="form-control" id="hora" name="hora"
                                                   value="<%= cita ? cita.hora : '' %>" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="estado" class="form-label fw-semibold">Estado de Cita</label>
                                            <select class="form-select" id="estado" name="estado" required>
                                                <option value="pendiente" <%= cita && cita.estado === 'pendiente' ? 'selected' : '' %>>⏳ Pendiente (Por Confirmar)</option>
                                                <option value="confirmada" <%= cita && cita.estado === 'confirmada' ? 'selected' : '' %>>✅ Confirmada</option>
                                                <option value="cancelada" <%= cita && cita.estado === 'cancelada' ? 'selected' : '' %>>❌ Cancelada</option>
                                                <option value="reagendada" <%= cita && cita.estado === 'reagendada' ? 'selected' : '' %>>🔄 Reagendada</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label for="motivo" class="form-label fw-semibold">Motivo o Descripción de Consulta</label>
                                        <textarea class="form-control" id="motivo" name="motivo" rows="3" required
                                            placeholder="Escribe el motivo de la consulta..."><%= cita ? cita.motivo : '' %></textarea>
                                    </div>

                                    <div class="mb-4">
                                        <label for="notas" class="form-label fw-semibold">
                                            Notas Privadas <span class="text-muted fw-normal">(Opcional, visible solo para ti)</span>
                                        </label>
                                        <textarea class="form-control" id="notas" name="notas" rows="3"
                                            placeholder="Añadir notas médicas sobre el paciente o consulta..."><%= cita ? cita.notas : '' %></textarea>
                                    </div>

                                    <div class="d-flex gap-2 pt-2">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-save-fill me-1"></i>
                                            <%= cita ? 'Guardar Cambios' : 'Agendar Cita' %>
                                        </button>
                                        <a href="/citas" class="btn btn-outline-secondary">Cancelar</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleDark() {
            const html = document.documentElement;
            const isDark = html.getAttribute('data-theme') === 'dark';
            const nextTheme = isDark ? '' : 'dark';
            html.setAttribute('data-theme', nextTheme);
            html.setAttribute('data-bs-theme', nextTheme === 'dark' ? 'dark' : 'light');
            const btn = document.getElementById('dark-toggle-btn');
            if (btn) {
                btn.innerHTML = isDark
                    ? '<i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro'
                    : '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
            }
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
        }

        document.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem('theme') === 'dark') {
                const btn = document.getElementById('dark-toggle-btn');
                if (btn) btn.innerHTML = '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
            }
            if (window.lucide) window.lucide.createIcons();
        });

        async function loadUnreadCount() {
            try {
                const res = await fetch('/api/chat/no-leidos');
                const data = await res.json();
                const dot = document.getElementById('unread-dot');
                if (dot) dot.style.display = data.count > 0 ? 'inline-block' : 'none';
            } catch (e) {}
        }
        loadUnreadCount();

        const sseConn = new EventSource('/api/updates/live');
        sseConn.addEventListener('wa_status', e => {
            const d = JSON.parse(e.data);
            const dot = document.getElementById('ws-status-icon');
            const text = document.getElementById('ws-status-text');
            const qrContainer = document.getElementById('ws-qr-container');
            const qrImg = document.getElementById('ws-qr-img');
            if (d.status === 'conectado') {
                if (dot) dot.className = 'wa-dot on';
                if (text) text.innerText = '✅ Conectado y listo';
                if (qrContainer) qrContainer.classList.add('d-none');
            } else {
                if (dot) dot.className = 'wa-dot off';
                if (text) text.innerText = `⚠️ ${d.status === 'qr_listo' ? 'Escanea el QR' : 'Desconectado'}`;
                if (d.qr || d.qrCode) {
                    if (qrImg) qrImg.src = d.qr || d.qrCode;
                    if (qrContainer) qrContainer.classList.remove('d-none');
                }
            }
        });
        sseConn.addEventListener('mensaje', e => {
            const d = JSON.parse(e.data);
            if (d.remitente === 'paciente') {
                const dot = document.getElementById('unread-dot');
                if (dot) dot.style.display = 'inline-block';
            }
        });

        window.addEventListener('beforeunload', () => {
            if (sseConn) sseConn.close();
        });

        async function reconectarWA() {
            try { await fetch('/api/whatsapp/reconectar', { method: 'POST' }); } catch (e) {}
        }
    </script>
</body>
</html>
