<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración del Consultorio - Citas Médicas</title>
    <meta name="description" content="Configura el horario, días laborales y ubicación del consultorio médico">
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Estilos compartidos -->
        <link rel="stylesheet" href="/css/app.css">
        <script src="/js/mobile-toggle.js" defer></script>
    <script>
        (function() {
            const t = localStorage.getItem('theme');
            if (t === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
            const c = localStorage.getItem('color-theme') || 'clinico';
            document.documentElement.setAttribute('data-color-theme', c);
        })();
    </script>
    <style>
        /* Estilos específicos para los checkboxes de días */
        .day-checkbox { display: none; }
        .day-label {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 52px;
            height: 40px;
            border-radius: 8px;
            background-color: var(--surface-color);
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.82rem;
            cursor: pointer;
            transition: all 0.2s;
            user-select: none;
        }
        .day-label:hover {
            border-color: var(--color-primary);
            color: var(--color-primary);
            background-color: rgba(37, 99, 235, 0.04);
        }
        .day-checkbox:checked + .day-label {
            background-color: var(--color-primary);
            border-color: var(--color-primary);
            color: white;
        }
        [data-theme="dark"] .day-label {
            background-color: rgba(255,255,255,0.04);
            border-color: rgba(255,255,255,0.1);
            color: var(--text-muted);
        }
        [data-theme="dark"] .day-checkbox:checked + .day-label {
            background-color: var(--color-primary);
            border-color: var(--color-primary);
            color: white;
        }
    </style>
</head>
<body>
    

    <div class="container-fluid">
        <div class="row flex-nowrap">
            <!-- Sidebar Navigation -->
            <div class="col-md-2 sidebar p-0 d-flex flex-column d-none d-md-flex">
                <div class="p-4 brand-title d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-hospital fs-4" style="color:#818cf8"></i>
                    <span class="fs-5">Citas Médicas</span>
                </div>
                <nav class="nav flex-column">
                    <a class="nav-link" href="/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                    <a class="nav-link" href="/citas"><i class="bi bi-calendar3"></i> Citas</a>
                    <a class="nav-link" href="/pacientes"><i class="bi bi-people-fill"></i> Pacientes</a>
                    <a class="nav-link" href="/mensajes"><i class="bi bi-chat-left-dots-fill"></i> Mensajes</a>
                    <a class="nav-link" href="/chat"><i class="bi bi-chat-dots-fill"></i> Chat en Vivo <span class="badge-dot ms-auto" id="unread-dot" style="display:none"></span></a>
                    <a class="nav-link" href="/analytics"><i class="bi bi-bar-chart-line-fill"></i> Analytics</a>
                    <a class="nav-link active" href="/configuracion"><i class="bi bi-gear-fill"></i> Configuración</a>
                </nav>

                <!-- WhatsApp Status Widget -->
                <div class="wa-status-widget mx-2 mt-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="wa-dot off" id="ws-status-icon"></span>
                        <span class="fw-semibold small text-main">WhatsApp Bot</span>
                    </div>
                    <div id="ws-status-text" class="small text-muted">Consultando...</div>
                    <div id="ws-qr-container" class="mt-2 text-center d-none">
                        <img id="ws-qr-img" src="" alt="Escanee QR" class="img-fluid rounded" style="max-height:120px">
                        <div class="small mt-1 text-warning">📱 Escanee para conectar</div>
                    </div>
                    <button onclick="reconectarWA()" class="btn btn-sm w-100 mt-2">
                        <i class="bi bi-arrow-repeat me-1"></i>Reconectar
                    </button>
                </div>

                <div class="px-3 py-2 mt-auto mb-2">
                    <button class="btn-sidebar-action mb-2 animate-hover" onclick="toggleDark()" id="dark-toggle-btn">
                        <i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro
                    </button>
                    <a href="/logout" class="btn-sidebar-action btn-sidebar-danger animate-hover">
                        <i class="bi bi-box-arrow-left"></i> Cerrar Sesión
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 main-content">

                <div class="page-header">
                    <div>
                        <h2>Configuración del Consultorio</h2>
                        <p>Establece tu horario de atención, días laborales, duración de citas e indicaciones</p>
                    </div>
                </div>

                <% if (success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius:8px;">
                        <i class="bi bi-check-circle-fill me-2"></i> <%= message %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <form action="/configuracion" method="POST">
                    <div class="row g-4">
                        <!-- Columna Izquierda: Horarios y Días -->
                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">
                                    <i class="bi bi-clock-fill me-2 text-primary"></i> Horario de Atención
                                </div>
                                <div class="card-body">
                                    <div class="row mb-4">
                                        <div class="col-6">
                                            <label for="hora_inicio" class="form-label fw-semibold">Hora de Inicio</label>
                                            <input type="time" class="form-control" id="hora_inicio" name="hora_inicio"
                                                value="<%= config.hora_inicio %>" required>
                                        </div>
                                        <div class="col-6">
                                            <label for="hora_fin" class="form-label fw-semibold">Hora de Cierre</label>
                                            <input type="time" class="form-control" id="hora_fin" name="hora_fin"
                                                value="<%= config.hora_fin %>" required>
                                        </div>
                                    </div>

                                    <div class="row mb-4">
                                        <div class="col-6">
                                            <label for="receso_inicio" class="form-label fw-semibold">Inicio de Receso (Opcional)</label>
                                            <input type="time" class="form-control" id="receso_inicio" name="receso_inicio"
                                                value="<%= config.receso_inicio || '' %>">
                                        </div>
                                        <div class="col-6">
                                            <label for="receso_fin" class="form-label fw-semibold">Fin de Receso (Opcional)</label>
                                            <input type="time" class="form-control" id="receso_fin" name="receso_fin"
                                                value="<%= config.receso_fin || '' %>">
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label for="duracion_cita" class="form-label fw-semibold">Duración de Cita</label>
                                        <select class="form-select" id="duracion_cita" name="duracion_cita" required>
                                            <option value="15" <%= config.duracion_cita === 15 ? 'selected' : '' %>>15 minutos</option>
                                            <option value="20" <%= config.duracion_cita === 20 ? 'selected' : '' %>>20 minutos</option>
                                            <option value="30" <%= config.duracion_cita === 30 ? 'selected' : '' %>>30 minutos</option>
                                            <option value="45" <%= config.duracion_cita === 45 ? 'selected' : '' %>>45 minutos</option>
                                            <option value="60" <%= config.duracion_cita === 60 ? 'selected' : '' %>>1 hora</option>
                                            <option value="90" <%= config.duracion_cita === 90 ? 'selected' : '' %>>1.5 horas</option>
                                            <option value="120" <%= config.duracion_cita === 120 ? 'selected' : '' %>>2 horas</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold d-block mb-3">Días Laborales</label>
                                        <%
                                            let diasLaborales = [];
                                            try {
                                                diasLaborales = JSON.parse(config.dias_laborales || '[]');
                                            } catch (e) {
                                                diasLaborales = [1,2,3,4,5];
                                            }
                                            const diasMap = [
                                                { val: 1, label: 'Lun' },
                                                { val: 2, label: 'Mar' },
                                                { val: 3, label: 'Mié' },
                                                { val: 4, label: 'Jue' },
                                                { val: 5, label: 'Vie' },
                                                { val: 6, label: 'Sáb' },
                                                { val: 0, label: 'Dom' }
                                            ];
                                        %>
                                        <div class="d-flex flex-wrap gap-2">
                                            <% diasMap.forEach(d => { %>
                                                <div>
                                                    <input type="checkbox" class="day-checkbox"
                                                        id="dia_<%= d.val %>" name="dias_laborales" value="<%= d.val %>"
                                                        <%= diasLaborales.includes(d.val) ? 'checked' : '' %>>
                                                    <label class="day-label" for="dia_<%= d.val %>"><%= d.label %></label>
                                                </div>
                                            <% }) %>
                                        </div>
                                    </div>

                                    <div class="mt-4">
                                        <label for="telefono_doctor" class="form-label fw-semibold">Teléfono del Médico (Notificaciones WhatsApp)</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-bell-fill text-primary"></i></span>
                                            <input type="text" class="form-control" id="telefono_doctor" name="telefono_doctor"
                                                value="<%= config.telefono_doctor || '' %>"
                                                placeholder="Ej: 5215512345678 (con código de país)">
                                        </div>
                                        <div class="form-text mt-2">
                                            <i class="bi bi-info-circle"></i> Recibirás avisos en tiempo real cada vez que un paciente agende, confirme o cancele una cita.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Columna Derecha: Ubicación -->
                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">
                                    <i class="bi bi-geo-alt-fill me-2 text-danger"></i> Ubicación del Consultorio
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label for="direccion" class="form-label fw-semibold">Dirección Física</label>
                                        <textarea class="form-control" id="direccion" name="direccion" rows="2"
                                            placeholder="Av. Benito Juárez 123, Toluca Centro..." required><%= config.direccion %></textarea>
                                    </div>

                                    <div class="mb-3">
                                        <label for="google_maps_url" class="form-label fw-semibold">Enlace de Google Maps</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-map-fill text-danger"></i></span>
                                            <input type="url" class="form-control" id="google_maps_url" name="google_maps_url"
                                                value="<%= config.google_maps_url %>"
                                                placeholder="https://maps.app.goo.gl/..." required>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="indicaciones" class="form-label fw-semibold">Indicaciones Previas / Preparación</label>
                                        <textarea class="form-control" id="indicaciones" name="indicaciones" rows="4"
                                            placeholder="Por favor llegar 10 minutos antes y traer su identificación..." required><%= config.indicaciones %></textarea>
                                        <div class="form-text mt-2">
                                            <i class="bi bi-info-circle"></i> Estas indicaciones se enviarán automáticamente al confirmar la cita.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fila 2: Personalización del Chatbot -->
                    <div class="row g-4 mt-1">
                        <div class="col-12">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-transparent border-0 pt-4 pb-0">
                                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-robot me-2"></i> Personalización del Chatbot de WhatsApp</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row text-start">
                                        <div class="col-md-6 mb-3">
                                            <label for="mensaje_bienvenida" class="form-label fw-semibold">Mensaje de Bienvenida / Menú Principal</label>
                                            <textarea class="form-control" id="mensaje_bienvenida" name="mensaje_bienvenida" rows="6" required><%= config.mensaje_bienvenida %></textarea>
                                            <div class="form-text mt-2">
                                                <i class="bi bi-info-circle"></i> Mensaje de inicio del chatbot. Soporta negritas de WhatsApp (ej: *texto*) y saltos de línea.
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label for="mensaje_ayuda" class="form-label fw-semibold">Mensaje de Ayuda y Soporte</label>
                                            <textarea class="form-control" id="mensaje_ayuda" name="mensaje_ayuda" rows="6" required><%= config.mensaje_ayuda %></textarea>
                                            <div class="form-text mt-2">
                                                <i class="bi bi-info-circle"></i> Mensaje que se envía cuando el paciente escribe "ayuda" o "help".
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row text-start mt-3">
                                        <div class="col-md-6 mb-3">
                                            <label for="max_mensajes_dia" class="form-label fw-semibold">Límite Diario de Mensajes por Paciente</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-chat-left-dots-fill text-primary"></i></span>
                                                <input type="number" class="form-control" id="max_mensajes_dia" name="max_mensajes_dia"
                                                    value="<%= config.max_mensajes_dia !== undefined ? config.max_mensajes_dia : 15 %>" min="1" max="500" required>
                                            </div>
                                            <div class="form-text mt-2">
                                                <i class="bi bi-info-circle"></i> Número máximo de mensajes que el chatbot/recordatorios enviará a un paciente por día (evita spam y bloqueos de WhatsApp).
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fila 3: Personalización de Temas Visuales (Branding) -->
                    <div class="row g-4 mt-1">
                        <div class="col-12">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-transparent border-0 pt-4 pb-0">
                                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-palette-fill me-2"></i> Tema Visual y Personalización (Branding)</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row text-start align-items-center">
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <label for="color-theme-select" class="form-label fw-semibold">Seleccionar Tema de Color</label>
                                            <select class="form-select" id="color-theme-select" onchange="changeColorTheme(this.value)">
                                                <option value="clinico">🩺 Clínico Clásico (Azul)</option>
                                                <option value="lavanda">🪻 Lavanda Relax (Morado)</option>
                                                <option value="bosque">🌲 Bosque Eco (Verde)</option>
                                                <option value="cyberpunk">🌸 Cyberpunk Neon (Rosa)</option>
                                                <option value="oled">🌌 OLED Dark (Negro Absoluto)</option>
                                            </select>
                                            <div class="form-text mt-2">
                                                Elige una paleta de colores para tu consultorio. El tema se aplicará automáticamente a todas las páginas de gestión.
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 rounded border text-muted" id="theme-preview-card" style="font-size:0.85rem; background-color: var(--surface-color); border-color: var(--border-color);">
                                                <strong>Vista Previa del Tema:</strong><br>
                                                El color primario del sistema y la cabecera se adaptarán de acuerdo a la paleta seleccionada. Haz clic para experimentar con los diferentes estilos.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fila 4: Tipos de Cita y Bloqueos de Agenda (Avanzado) -->
                    <div class="row g-4 mt-1">
                        <!-- Servicios (Tipos de Consulta) -->
                        <div class="col-lg-6">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-transparent border-0 pt-4 pb-0">
                                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-tags-fill me-2"></i> Tipos de Consulta / Servicios</h5>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive mb-3" style="max-height: 250px;">
                                        <table class="table table-hover align-middle table-sm border-0" id="table-servicios">
                                            <thead>
                                                <tr>
                                                    <th>Servicio</th>
                                                    <th>Duración</th>
                                                    <th class="text-end">Acción</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <!-- Cargado vía JS -->
                                            </tbody>
                                        </table>
                                    </div>
                                    <hr class="text-muted opacity-25">
                                    <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle-fill me-1"></i> Agregar Nuevo Servicio</h6>
                                    <div class="row g-2">
                                        <div class="col-sm-7">
                                            <input type="text" class="form-control form-control-sm" id="srv-nombre" placeholder="Nombre del servicio (ej: Limpieza)">
                                        </div>
                                        <div class="col-sm-5">
                                            <select class="form-select form-select-sm" id="srv-duracion">
                                                <option value="15">15 min</option>
                                                <option value="20">20 min</option>
                                                <option value="30" selected>30 min</option>
                                                <option value="45">45 min</option>
                                                <option value="60">60 min (1h)</option>
                                                <option value="90">90 min</option>
                                                <option value="120">120 min (2h)</option>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <input type="text" class="form-control form-control-sm" id="srv-descripcion" placeholder="Descripción breve (opcional)">
                                        </div>
                                        <div class="col-12 text-end mt-2">
                                            <button type="button" class="btn btn-sm btn-primary" onclick="agregarServicio()">
                                                <i class="bi bi-plus-lg"></i> Agregar
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Bloqueos de Agenda -->
                        <div class="col-lg-6">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-transparent border-0 pt-4 pb-0">
                                    <h5 class="fw-bold mb-0 text-danger"><i class="bi bi-calendar-x-fill me-2"></i> Bloqueos de Agenda (Días Inhábiles)</h5>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive mb-3" style="max-height: 250px;">
                                        <table class="table table-hover align-middle table-sm border-0" id="table-bloqueos">
                                            <thead>
                                                <tr>
                                                    <th>Fecha</th>
                                                    <th>Horario</th>
                                                    <th>Motivo</th>
                                                    <th class="text-end">Acción</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <!-- Cargado vía JS -->
                                            </tbody>
                                        </table>
                                    </div>
                                    <hr class="text-muted opacity-25">
                                    <h6 class="fw-bold mb-3"><i class="bi bi-shield-lock-fill me-1"></i> Bloquear Fecha/Hora</h6>
                                    <div class="row g-2">
                                        <div class="col-sm-6">
                                            <input type="date" class="form-control form-control-sm" id="blk-fecha">
                                        </div>
                                        <div class="col-sm-3">
                                            <input type="time" class="form-control form-control-sm" id="blk-hora-inicio" placeholder="Inicio (opcional)">
                                        </div>
                                        <div class="col-sm-3">
                                            <input type="time" class="form-control form-control-sm" id="blk-hora-fin" placeholder="Fin (opcional)">
                                        </div>
                                        <div class="col-12">
                                            <input type="text" class="form-control form-control-sm" id="blk-descripcion" placeholder="Motivo (ej: Vacaciones, Congreso)">
                                        </div>
                                        <div class="col-12 text-end mt-2">
                                            <button type="button" class="btn btn-sm btn-danger" onclick="agregarBloqueo()">
                                                <i class="bi bi-lock-fill"></i> Crear Bloqueo
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Botón de Envío -->
                    <div class="row mt-4">
                        <div class="col-12 text-end mb-4">
                            <button type="submit" class="btn btn-primary px-5">
                                <i class="bi bi-save me-2"></i> Guardar Cambios
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleDark() {
            const html = document.documentElement;
            const isDark = html.getAttribute('data-theme') === 'dark';
            const nextTheme = isDark ? '' : 'dark';
            html.setAttribute('data-theme', nextTheme);
            html.setAttribute('data-bs-theme', nextTheme === 'dark' ? 'dark' : 'light');
            const btn = document.getElementById('dark-toggle-btn');
            if (btn) {
                btn.innerHTML = isDark
                    ? '<i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro'
                    : '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
            }
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
        }

        function changeColorTheme(val) {
            document.documentElement.setAttribute('data-color-theme', val);
            localStorage.setItem('color-theme', val);
            updateThemePreviewCard(val);
        }

        function updateThemePreviewCard(val) {
            const card = document.getElementById('theme-preview-card');
            if (!card) return;
            let text = '';
            let style = '';
            if (val === 'clinico') {
                text = '🩺 <strong>Clínico Clásico</strong>: Estilo médico clásico, formal y profesional basado en azul cobalto.';
                style = 'border-left: 5px solid #2563eb; background-color: rgba(37, 99, 235, 0.03); border-color: var(--border-color);';
            } else if (val === 'lavanda') {
                text = '🪻 <strong>Lavanda Relax</strong>: Atmósfera calmada y moderna en tonos lila, ideal para psicología y rehabilitación.';
                style = 'border-left: 5px solid #8b5cf6; background-color: rgba(139, 92, 246, 0.03); border-color: var(--border-color);';
            } else if (val === 'bosque') {
                text = '🌲 <strong>Bosque Eco</strong>: Diseño orgánico en tonos verdes esmeralda, ideal para consultorios holísticos y nutrición.';
                style = 'border-left: 5px solid #059669; background-color: rgba(5, 150, 105, 0.03); border-color: var(--border-color);';
            } else if (val === 'cyberpunk') {
                text = '🌸 <strong>Cyberpunk Neon</strong>: Combinación vibrante de rosa y magenta neón para una estética audaz y de vanguardia.';
                style = 'border-left: 5px solid #ec4899; background-color: rgba(236, 72, 153, 0.03); border-color: var(--border-color);';
            } else if (val === 'oled') {
                text = '🌌 <strong>OLED Dark</strong>: Negro puro y contrastes violeta. Optimizado para pantallas OLED y reducción de fatiga visual.';
                style = 'border-left: 5px solid #c084fc; background-color: rgba(192, 132, 252, 0.03); border-color: var(--border-color);';
            }
            card.style = style;
            card.innerHTML = text;
        }

        document.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem('theme') === 'dark') {
                const btn = document.getElementById('dark-toggle-btn');
                if (btn) btn.innerHTML = '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
            }
            const currentTheme = localStorage.getItem('color-theme') || 'clinico';
            const select = document.getElementById('color-theme-select');
            if (select) select.value = currentTheme;
            updateThemePreviewCard(currentTheme);

            if (window.lucide) window.lucide.createIcons();

            loadServicios();
            loadBloqueos();
        });

        async function loadUnreadCount() {
            try {
                const res = await fetch('/api/chat/no-leidos');
                const data = await res.json();
                const dot = document.getElementById('unread-dot');
                if (dot) dot.style.display = data.count > 0 ? 'inline-block' : 'none';
            } catch (e) {}
        }
        loadUnreadCount();

        const sseConn = new EventSource('/api/updates/live');
        sseConn.addEventListener('wa_status', e => {
            const d = JSON.parse(e.data);
            const dot = document.getElementById('ws-status-icon');
            const text = document.getElementById('ws-status-text');
            const qrContainer = document.getElementById('ws-qr-container');
            const qrImg = document.getElementById('ws-qr-img');
            if (d.status === 'conectado') {
                if (dot) dot.className = 'wa-dot on';
                if (text) text.innerText = '✅ Conectado y listo';
                if (qrContainer) qrContainer.classList.add('d-none');
            } else {
                if (dot) dot.className = 'wa-dot off';
                if (text) text.innerText = `⚠️ ${d.status === 'qr_listo' ? 'Escanea el QR' : 'Desconectado'}`;
                if (d.qr || d.qrCode) {
                    if (qrImg) qrImg.src = d.qr || d.qrCode;
                    if (qrContainer) qrContainer.classList.remove('d-none');
                }
            }
        });
        sseConn.addEventListener('mensaje', e => {
            const d = JSON.parse(e.data);
            if (d.remitente === 'paciente') {
                const dot = document.getElementById('unread-dot');
                if (dot) dot.style.display = 'inline-block';
            }
        });

        window.addEventListener('beforeunload', () => {
            if (sseConn) sseConn.close();
        });

        async function reconectarWA() {
            try { await fetch('/api/whatsapp/reconectar', { method: 'POST' }); } catch (e) {}
        }

        // Funciones para Gestión de Servicios
        async function loadServicios() {
            try {
                const res = await fetch('/api/servicios');
                const list = await res.json();
                const tbody = document.querySelector('#table-servicios tbody');
                tbody.innerHTML = '';
                if (list.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">No hay servicios registrados.</td></tr>';
                    return;
                }
                list.forEach(s => {
                    tbody.innerHTML += `
                        <tr>
                            <td><strong>${s.nombre}</strong><br><small class="text-muted">${s.descripcion || ''}</small></td>
                            <td><span class="badge bg-secondary">${s.duracion} min</span></td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="eliminarServicio(${s.id})">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
            } catch (err) { console.error('Error cargando servicios:', err); }
        }

        async function agregarServicio() {
            const nombre = document.getElementById('srv-nombre').value;
            const duracion = document.getElementById('srv-duracion').value;
            const descripcion = document.getElementById('srv-descripcion').value;

            if (!nombre) {
                alert('Ingresa el nombre del servicio.');
                return;
            }

            try {
                const res = await fetch('/api/servicios', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, duracion, descripcion })
                });
                if (res.ok) {
                    document.getElementById('srv-nombre').value = '';
                    document.getElementById('srv-descripcion').value = '';
                    loadServicios();
                } else {
                    const data = await res.json();
                    alert('Error: ' + data.error);
                }
            } catch (err) { alert('Error agregando servicio.'); }
        }

        async function eliminarServicio(id) {
            if (!confirm('¿Estás seguro de eliminar este servicio?')) return;
            try {
                const res = await fetch(`/api/servicios/${id}`, { method: 'DELETE' });
                if (res.ok) loadServicios();
            } catch (err) { alert('Error al eliminar servicio.'); }
        }

        // Funciones para Bloqueos de Agenda
        async function loadBloqueos() {
            try {
                const res = await fetch('/api/bloqueos');
                const list = await res.json();
                const tbody = document.querySelector('#table-bloqueos tbody');
                tbody.innerHTML = '';
                if (list.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">No hay bloqueos configurados.</td></tr>';
                    return;
                }
                list.forEach(b => {
                    const fDisp = b.fecha.split('-').reverse().join('/');
                    const horario = (b.hora_inicio && b.hora_fin) ? `${b.hora_inicio} - ${b.hora_fin}` : 'Todo el día';
                    tbody.innerHTML += `
                        <tr>
                            <td><strong>${fDisp}</strong></td>
                            <td><span class="badge bg-danger-subtle text-danger">${horario}</span></td>
                            <td><small class="text-muted">${b.descripcion || '-'}</small></td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="eliminarBloqueo(${b.id})">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
            } catch (err) { console.error('Error cargando bloqueos:', err); }
        }

        async function agregarBloqueo() {
            const fecha = document.getElementById('blk-fecha').value;
            const hora_inicio = document.getElementById('blk-hora-inicio').value;
            const hora_fin = document.getElementById('blk-hora-fin').value;
            const descripcion = document.getElementById('blk-descripcion').value;

            if (!fecha) {
                alert('Selecciona una fecha para el bloqueo.');
                return;
            }

            try {
                const res = await fetch('/api/bloqueos', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fecha, hora_inicio, hora_fin, descripcion })
                });
                if (res.ok) {
                    document.getElementById('blk-fecha').value = '';
                    document.getElementById('blk-hora-inicio').value = '';
                    document.getElementById('blk-hora-fin').value = '';
                    document.getElementById('blk-descripcion').value = '';
                    loadBloqueos();
                } else {
                    const data = await res.json();
                    alert('Error: ' + data.error);
                }
            } catch (err) { alert('Error agregando bloqueo.'); }
        }

        async function eliminarBloqueo(id) {
            if (!confirm('¿Estás seguro de eliminar este bloqueo?')) return;
            try {
                const res = await fetch(`/api/bloqueos/${id}`, { method: 'DELETE' });
                if (res.ok) loadBloqueos();
            } catch (err) { alert('Error al eliminar bloqueo.'); }
        }
    </script>
</body>
</html>
