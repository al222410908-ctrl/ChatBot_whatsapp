<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mensajería WhatsApp - Citas Médicas</title>
    <meta name="description" content="Envío de mensajes manuales y gestión de mensajería automática WhatsApp">
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Estilos compartidos -->
        <link rel="stylesheet" href="/css/app.css">
    <script>
        (function() {
            const t = localStorage.getItem('theme');
            if (t === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
            const c = localStorage.getItem('color-theme') || 'clinico';
            document.documentElement.setAttribute('data-color-theme', c);
        })();
    </script>
    <style>
        .msg-preview { max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: inline-block; }
        .template-btn {
            text-align: left;
            border-radius: var(--border-radius);
            padding: 12px 16px;
            font-size: 0.88rem;
            font-weight: 500;
            transition: all 0.2s ease-in-out;
            background-color: var(--surface-color);
            border: 1px solid var(--border-color);
            color: var(--text-main);
        }
        .template-btn:hover {
            transform: translateX(4px);
            background-color: rgba(100, 116, 139, 0.04);
            color: var(--text-main);
            border-color: var(--border-hover);
        }
        [data-theme="dark"] .template-btn:hover {
            background-color: rgba(255, 255, 255, 0.03);
        }
        .antispam-info {
            background: rgba(16, 185, 129, 0.05);
            border: 1px solid rgba(16, 185, 129, 0.2);
            color: #065f46;
            border-radius: var(--border-radius);
            padding: 16px;
        }
        [data-theme="dark"] .antispam-info {
            background: rgba(16, 185, 129, 0.08);
            border-color: rgba(16, 185, 129, 0.25);
            color: #a7f3d0;
        }
        .wa-check-result { margin-top: 8px; font-size: 0.85rem; }
        /* Contador de caracteres que cambia color */
        .char-ok  { color: #16a34a; }
        .char-warn { color: #d97706; }
        .char-err  { color: #dc2626; }
    </style>
</head>
<body>
    
<div class="container-fluid">
    <div class="row flex-nowrap">
        <!-- Sidebar -->
        <div class="col-md-2 sidebar p-0 d-flex flex-column d-none d-md-flex">
            <div class="p-4 brand-title d-flex align-items-center gap-2 mb-3">
                <i class="bi bi-hospital fs-4" style="color:#818cf8"></i>
                <span class="fs-5">Citas Médicas</span>
            </div>
            <nav class="nav flex-column">
                <a class="nav-link" href="/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/citas"><i class="bi bi-calendar3"></i> Citas</a>
                <a class="nav-link" href="/pacientes"><i class="bi bi-people-fill"></i> Pacientes</a>
                <a class="nav-link active" href="/mensajes"><i class="bi bi-chat-left-dots-fill"></i> Mensajes</a>
                <a class="nav-link" href="/chat"><i class="bi bi-chat-dots-fill"></i> Chat en Vivo <span class="badge-dot ms-auto" id="unread-dot" style="display:none"></span></a>
                <a class="nav-link" href="/analytics"><i class="bi bi-bar-chart-line-fill"></i> Analytics</a>
                <a class="nav-link" href="/configuracion"><i class="bi bi-gear-fill"></i> Configuración</a>
            </nav>

            <!-- WhatsApp Status Widget -->
            <div class="wa-status-widget mx-2 mt-3">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="wa-dot off" id="ws-status-icon"></span>
                    <span class="fw-semibold small text-main">WhatsApp Bot</span>
                </div>
                <div id="ws-status-text" class="small text-muted">Consultando...</div>
                <div id="ws-qr-container" class="mt-2 text-center d-none">
                    <img id="ws-qr-img" src="" alt="Escanee QR" class="img-fluid rounded" style="max-height:120px">
                    <div class="small mt-1 text-warning">📱 Escanee para conectar</div>
                </div>
                <button onclick="reconectarWA()" class="btn btn-sm w-100 mt-2">
                    <i class="bi bi-arrow-repeat me-1"></i>Reconectar
                </button>
            </div>

            <div class="px-3 py-2 mt-auto mb-2">
                <button class="btn-sidebar-action mb-2 animate-hover" onclick="toggleDark()" id="dark-toggle-btn">
                    <i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro
                </button>
                <a href="/logout" class="btn-sidebar-action btn-sidebar-danger animate-hover">
                    <i class="bi bi-box-arrow-left"></i> Cerrar Sesión
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-10 main-content">
            <div class="page-header">
                <div>
                    <h2>Mensajería WhatsApp</h2>
                    <p>Envía notificaciones manuales y revisa el historial de mensajes</p>
                </div>
                <div id="antispam-horario-badge"></div>
            </div>

            <!-- Banner de advertencia WA desconectado -->
            <div id="wa-warning-banner" class="wa-disconnected-banner d-none mb-3">
                <i class="bi bi-exclamation-triangle-fill fs-5 text-warning"></i>
                <div class="flex-grow-1">
                    <strong>WhatsApp desconectado</strong> — Los mensajes no se podrán enviar hasta reconectar.
                </div>
            </div>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> <%= message %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <% if (typeof error !== 'undefined' && error && error !== '') { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="row">
                <!-- Columna izquierda: Formulario + Historial -->
                <div class="col-lg-8">
                    <!-- Formulario de envío -->
                    <div class="card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Redactar Mensaje</h5>
                            <span class="antispam-badge"><i class="bi bi-shield-check"></i> Anti-spam activo</span>
                        </div>
                        <div class="card-body">
                            <form action="/mensajes/enviar" method="POST" id="send-form">
                                <div class="mb-3">
                                    <label for="telefono" class="form-label fw-semibold">Número de Teléfono</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                        <input type="tel" class="form-control" id="telefono" name="telefono"
                                               required placeholder="Ej: 7221234567"
                                               oninput="checkWaNumber(this.value)">
                                        <button class="btn btn-outline-secondary" type="button" onclick="checkWaNumber(document.getElementById('telefono').value)" title="Verificar si tiene WhatsApp">
                                            <i class="bi bi-whatsapp text-success"></i> Verificar
                                        </button>
                                    </div>
                                    <div id="wa-check-result" class="wa-check-result"></div>
                                    <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle"></i> Ingresa 10 dígitos o con código de país. El sistema lo normalizará.</small>
                                </div>
                                <div class="mb-3">
                                    <label for="mensaje" class="form-label fw-semibold">Mensaje</label>
                                    <textarea class="form-control" id="mensaje" name="mensaje" rows="5"
                                              required placeholder="Escribe tu mensaje o usa una plantilla de la derecha..."></textarea>
                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i>Los mensajes solo se envían entre 8:00 AM – 9:00 PM</small>
                                        <small><span id="charCount" class="fw-bold char-ok">0</span> caracteres</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <button type="submit" class="btn btn-primary" id="send-btn">
                                        <i class="bi bi-send-fill me-1"></i> Enviar Mensaje
                                    </button>
                                    <button type="reset" class="btn btn-outline-secondary" onclick="resetForm()">
                                        <i class="bi bi-x-circle me-1"></i> Limpiar
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Historial de Mensajes -->
                    <% if (mensajesPendientes && mensajesPendientes.length > 0) { %>
                    <div class="card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Historial Reciente</h5>
                            <a href="/api/citas/exportar-csv" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-download me-1"></i>Exportar CSV
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Destinatario</th>
                                            <th>Mensaje</th>
                                            <th>Tipo</th>
                                            <th>Estado</th>
                                            <th>Intentos</th>
                                            <th>Fecha</th>
                                            <th class="text-end">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% mensajesPendientes.forEach(msg => { %>
                                        <tr id="msg-<%= msg.id %>">
                                            <td class="fw-semibold">
                                                <i class="bi bi-whatsapp text-success me-1"></i>
                                                <span title="+<%= msg.telefono %>"><%= msg.paciente_nombre || ('+' + String(msg.telefono).substring(0, 13)) %></span>
                                            </td>
                                            <td>
                                                <span class="msg-preview text-muted" title="<%= msg.mensaje %>">
                                                    <%= msg.mensaje.substring(0, 45) %><%= msg.mensaje.length > 45 ? '…' : '' %>
                                                </span>
                                            </td>
                                            <td>
                                                <% if (msg.tipo === 'recordatorio') { %>
                                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25">
                                                        <i class="bi bi-bell-fill me-1"></i>Recordatorio
                                                    </span>
                                                <% } else if (msg.tipo === 'encuesta') { %>
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                                                        <i class="bi bi-star-fill me-1"></i>Encuesta
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">
                                                        <i class="bi bi-person-fill me-1"></i>Manual
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (msg.estado === 'enviado') { %>
                                                    <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Enviado</span>
                                                <% } else if (msg.estado === 'fallido') { %>
                                                    <span class="badge bg-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Fallido</span>
                                                <% } else { %>
                                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock-fill me-1"></i>Pendiente</span>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge <%= msg.intentos >= 3 ? 'bg-danger' : (msg.intentos >= 1 ? 'bg-warning text-dark' : 'bg-light text-muted border') %>">
                                                    <%= msg.intentos || 0 %>
                                                </span>
                                            </td>
                                            <td class="text-muted small">
                                                <%= new Date(msg.creado_en).toLocaleDateString('es-ES') %><br>
                                                <%= new Date(msg.creado_en).toLocaleTimeString('es-ES', {hour:'2-digit',minute:'2-digit'}) %>
                                            </td>
                                            <td class="text-end">
                                                <% if (msg.estado === 'pendiente' || msg.estado === 'fallido') { %>
                                                    <button class="btn btn-sm btn-outline-warning"
                                                            onclick="reintentarMensaje(<%= msg.id %>)"
                                                            id="btn-<%= msg.id %>">
                                                        <i class="bi bi-arrow-clockwise"></i>
                                                    </button>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="card mb-4">
                        <div class="card-body text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 opacity-40"></i>
                            <p class="mt-2 mb-0">No hay mensajes registrados todavía.</p>
                        </div>
                    </div>
                    <% } %>
                </div>

                <!-- Columna derecha: Plantillas + Info Anti-Spam -->
                <div class="col-lg-4">
                    <!-- Plantillas rápidas -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="fw-bold mb-0"><i class="bi bi-collection me-2 text-primary"></i>Plantillas Rápidas</h5>
                        </div>
                        <div class="card-body p-3 d-grid gap-2">
                            <button type="button" class="template-btn border-start border-primary border-3" onclick="useTemplate('recordatorio')">
                                <i class="bi bi-bell me-2 text-primary"></i>Recordatorio de cita
                            </button>
                            <button type="button" class="template-btn border-start border-success border-3" onclick="useTemplate('confirmacion')">
                                <i class="bi bi-check-circle me-2 text-success"></i>Confirmación de cita
                            </button>
                            <button type="button" class="template-btn border-start border-danger border-3" onclick="useTemplate('cancelacion')">
                                <i class="bi bi-x-circle me-2 text-danger"></i>Cancelación de cita
                            </button>
                            <button type="button" class="template-btn border-start border-info border-3" onclick="useTemplate('reagendar')">
                                <i class="bi bi-arrow-repeat me-2 text-info"></i>Reagendar cita
                            </button>
                            <button type="button" class="template-btn border-start border-warning border-3" onclick="useTemplate('bienvenida')">
                                <i class="bi bi-hand-wave me-2 text-warning"></i>Bienvenida al paciente
                            </button>
                        </div>
                    </div>

                    <!-- Info Anti-Spam -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="fw-bold mb-0"><i class="bi bi-shield-check me-2 text-success"></i>Protección Anti-Spam</h5>
                        </div>
                        <div class="card-body antispam-info">
                            <ul class="list-unstyled mb-0" style="font-size:0.88rem;line-height:1.7;">
                                <li class="mb-2">
                                    <i class="bi bi-clock-fill text-success me-2"></i>
                                    <strong>Horario seguro:</strong> 8:00 AM – 9:00 PM
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-hourglass-split text-info me-2"></i>
                                    <strong>Delay entre mensajes:</strong> 2 – 5 segundos
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-bar-chart-fill text-warning me-2"></i>
                                    <strong>Límite diario:</strong> 5 mensajes por número
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-shuffle text-primary me-2"></i>
                                    <strong>Variación de plantillas</strong> en recordatorios
                                </li>
                                <li>
                                    <i class="bi bi-arrow-repeat text-danger me-2"></i>
                                    <strong>Reintentos automáticos</strong> (hasta 5 intentos)
                                </li>
                            </ul>
                        </div>
                        <div class="card-body pt-0">
                            <small class="text-muted d-block" style="font-size:0.8rem;">
                                <i class="bi bi-info-circle me-1"></i>
                                Estas medidas protegen el número de WhatsApp del médico de ser bloqueado por envíos masivos.
                            </small>
                        </div>
                    </div>

                    <!-- Tips de uso -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="fw-bold mb-0"><i class="bi bi-lightbulb me-2 text-warning"></i>Tips de Uso</h5>
                        </div>
                        <div class="card-body" style="font-size:0.87rem;">
                            <div class="d-flex gap-2 mb-3">
                                <i class="bi bi-info-circle-fill text-primary flex-shrink-0 mt-1"></i>
                                <span class="text-muted">Los recordatorios automáticos se envían 24h antes de cada cita pendiente.</span>
                            </div>
                            <div class="d-flex gap-2 mb-3">
                                <i class="bi bi-exclamation-circle-fill text-warning flex-shrink-0 mt-1"></i>
                                <span class="text-muted">Si WhatsApp está desconectado, los mensajes quedan en cola y se envían al reconectar.</span>
                            </div>
                            <div class="d-flex gap-2">
                                <i class="bi bi-shield-fill-check text-success flex-shrink-0 mt-1"></i>
                                <span class="text-muted">Usa el botón "Verificar" para comprobar si el número del paciente tiene WhatsApp antes de enviar.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // ── Dark Mode ────────────────────────────────────────────────
    function toggleDark() {
        const html = document.documentElement;
        const isDark = html.getAttribute('data-theme') === 'dark';
        const nextTheme = isDark ? '' : 'dark';
        html.setAttribute('data-theme', nextTheme);
        html.setAttribute('data-bs-theme', nextTheme === 'dark' ? 'dark' : 'light');
        const btn = document.getElementById('dark-toggle-btn');
        if (btn) {
            btn.innerHTML = isDark
                ? '<i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro'
                : '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
        }
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
    }
    document.addEventListener('DOMContentLoaded', () => {
        if (localStorage.getItem('theme') === 'dark') {
            const btn = document.getElementById('dark-toggle-btn');
            if (btn) btn.innerHTML = '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
        }
    });

    async function reconectarWA() {
        try { await fetch('/api/whatsapp/reconectar', { method: 'POST' }); } catch (e) {}
    }

    // ── Contador de caracteres con color ──────────────────────
    const mensajeTextarea = document.getElementById('mensaje');
    const charCountEl = document.getElementById('charCount');
    mensajeTextarea.addEventListener('input', function () {
        const len = this.value.length;
        charCountEl.textContent = len;
        charCountEl.className = len > 800 ? 'fw-bold char-err' : len > 500 ? 'fw-bold char-warn' : 'fw-bold char-ok';
    });

    function resetForm() {
        document.getElementById('wa-check-result').innerHTML = '';
        charCountEl.textContent = '0';
        charCountEl.className = 'fw-bold char-ok';
    }

    // ── Plantillas ────────────────────────────────────────────
    const templates = {
        recordatorio: `🩺 *Recordatorio de Cita Médica*\n\nHola, te recordamos tu cita programada:\n\n📅 *Fecha:* [FECHA]\n⏰ *Hora:* [HORA]\n📍 *Lugar:* Consultorio\n📝 *Motivo:* Consulta\n\nPor favor responde para confirmar tu asistencia:\n1️⃣ *Confirmo* (o *"Si"*) — Confirmar asistencia\n2️⃣ *Cancelar* (o *"No"*) — Cancelar cita\n3️⃣ *Reagendar* — Cambiar fecha\n\nTambién puedes responder solo con el número (1, 2 o 3).`,
        confirmacion: `✅ *Cita Confirmada*\n\nTu cita médica ha sido confirmada exitosamente.\n\n📅 Fecha: [FECHA]\n⏰ Hora: [HORA]\n📝 Motivo: [MOTIVO]\n\nTe esperamos puntualmente. ¡Gracias! 🩺`,
        cancelacion: `❌ *Cancelación de Cita*\n\nTu cita médica ha sido cancelada.\n\nSi deseas agendar una nueva cita en el futuro, escribe *"cita"* o *"agendar"* y con gusto te atendemos.`,
        reagendar: `🔄 *Cita Reagendada*\n\nTu cita ha sido reagendada exitosamente.\n\n📅 Nueva Fecha: [FECHA]\n⏰ Nueva Hora: [HORA]\n\nTe enviaremos un recordatorio 24 horas antes. ¡Gracias!`,
        bienvenida: `👋 *¡Hola!*\n\nBienvenido/a a nuestro servicio. Soy tu asistente virtual y puedo ayudarte con:\n\n📅 *Agendar cita* — Escribe "cita"\n📋 *Consultar citas* — Escribe "mis citas"\n❌ *Cancelar cita* — Escribe "cancelar"\n\n¿En qué te puedo ayudar hoy? 🩺`
    };

    function useTemplate(name) {
        if (templates[name]) {
            mensajeTextarea.value = templates[name];
            const len = templates[name].length;
            charCountEl.textContent = len;
            charCountEl.className = len > 800 ? 'fw-bold char-err' : 'fw-bold char-ok';
            mensajeTextarea.focus();
        }
    }

    // ── Verificar número de WhatsApp ──────────────────────────
    let waCheckTimer = null;
    function checkWaNumber(value) {
        clearTimeout(waCheckTimer);
        const clean = value.replace(/\D/g, '');
        if (clean.length < 10) {
            document.getElementById('wa-check-result').innerHTML = '';
            return;
        }
        waCheckTimer = setTimeout(async () => {
            const resultEl = document.getElementById('wa-check-result');
            resultEl.innerHTML = '<span class="text-muted"><i class="bi bi-hourglass-split me-1"></i>Verificando...</span>';
            try {
                const res = await fetch(`/api/whatsapp/check-number/${clean}`);
                const data = await res.json();
                if (data.hasWhatsApp === true) {
                    resultEl.innerHTML = '<span class="text-success"><i class="bi bi-whatsapp me-1"></i>✅ Este número tiene WhatsApp activo</span>';
                } else if (data.hasWhatsApp === false) {
                    resultEl.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle me-1"></i>⚠️ Este número NO tiene WhatsApp registrado</span>';
                } else {
                    resultEl.innerHTML = `<span class="text-warning"><i class="bi bi-question-circle me-1"></i>${data.error || 'No se pudo verificar (WA desconectado)'}</span>`;
                }
            } catch (e) {
                resultEl.innerHTML = '<span class="text-muted">No se pudo verificar</span>';
            }
        }, 800);
    }

    // ── Reintentar mensaje individual ─────────────────────────
    async function reintentarMensaje(id) {
        const btn = document.getElementById('btn-' + id);
        if (!btn) return;
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';
        try {
            const res = await fetch('/mensajes/' + id + '/reintentar', { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                // Actualizar badge en la fila
                const row = document.getElementById('msg-' + id);
                const badgeCell = row.querySelectorAll('td')[3];
                if (badgeCell) badgeCell.innerHTML = '<span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Enviado</span>';
                btn.remove();
            } else {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i>';
                btn.title = 'Error: ' + (data.error || 'No se pudo enviar');
            }
        } catch (err) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i>';
        }
    }

    // ── Unread count ──────────────────────────────────────────
    async function loadUnreadCount() {
        try {
            const res = await fetch('/api/chat/no-leidos');
            const data = await res.json();
            const dot = document.getElementById('unread-dot');
            if (dot) dot.style.display = data.count > 0 ? 'inline-block' : 'none';
        } catch (e) {}
    }
    loadUnreadCount();

    // ── Badge de horario anti-spam ────────────────────────────
    async function checkHorario() {
        try {
            const res = await fetch('/api/sistema/estado');
            const data = await res.json();
            const badgeEl = document.getElementById('antispam-horario-badge');
            if (badgeEl) {
                if (!data.antispam.ventanaSegura) {
                    badgeEl.innerHTML = `<span class="antispam-badge" style="background:linear-gradient(135deg,#fee2e2,#fecaca);border-color:#ef4444;color:#991b1b;">
                        <i class="bi bi-moon"></i> Fuera de horario de envío
                    </span>`;
                } else {
                    badgeEl.innerHTML = `<span class="antispam-badge">
                        <i class="bi bi-shield-check"></i> Horario de envío activo
                    </span>`;
                }
            }
        } catch (e) {}
    }
    checkHorario();

    // ── SSE ───────────────────────────────────────────────────
    const sseConn = new EventSource('/api/updates/live');
    sseConn.addEventListener('wa_status', e => {
        const d = JSON.parse(e.data);
        const dot = document.getElementById('ws-status-icon');
        const text = document.getElementById('ws-status-text');
        const qrContainer = document.getElementById('ws-qr-container');
        const qrImg = document.getElementById('ws-qr-img');
        const banner = document.getElementById('wa-warning-banner');

        if (d.status === 'conectado') {
            if (dot) dot.className = 'wa-dot on';
            if (text) text.innerText = '✅ Conectado y listo';
            if (qrContainer) qrContainer.classList.add('d-none');
            if (banner) banner.classList.add('d-none');
        } else {
            if (dot) dot.className = 'wa-dot off';
            if (text) text.innerText = `⚠️ ${d.status === 'qr_listo' ? 'Escanea el QR' : 'Desconectado'}`;
            if (banner) banner.classList.remove('d-none');
            if ((d.qr || d.qrCode) && qrImg && qrContainer) {
                qrImg.src = d.qr || d.qrCode;
                qrContainer.classList.remove('d-none');
            }
        }
    });
    sseConn.addEventListener('mensaje', e => {
        const d = JSON.parse(e.data);
        if (d.remitente === 'paciente') {
            const dot = document.getElementById('unread-dot');
            if (dot) dot.style.display = 'inline-block';
        }
    });

    window.addEventListener('beforeunload', () => {
        if (sseConn) sseConn.close();
    });
</script>
</body>
</html>
