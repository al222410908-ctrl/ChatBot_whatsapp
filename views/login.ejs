<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acceso — Citas Médicas</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --indigo: #4f46e5;
      --indigo-dark: #3730a3;
      --emerald: #10b981;
      --surface: rgba(255,255,255,0.07);
      --border: rgba(255,255,255,0.12);
    }

    body {
      font-family: 'Outfit', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      overflow: hidden;
    }

    /* Animated background blobs */
    .blob {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.35;
      animation: float 8s ease-in-out infinite;
      pointer-events: none;
    }
    .blob-1 { width: 500px; height: 500px; background: #4f46e5; top: -100px; left: -100px; animation-delay: 0s; }
    .blob-2 { width: 400px; height: 400px; background: #7c3aed; bottom: -100px; right: -50px; animation-delay: -3s; }
    .blob-3 { width: 300px; height: 300px; background: #10b981; top: 50%; left: 50%; animation-delay: -5s; }

    @keyframes float {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33%       { transform: translate(30px, -30px) scale(1.05); }
      66%       { transform: translate(-20px, 20px) scale(0.95); }
    }

    .login-card {
      position: relative;
      z-index: 1;
      background: rgba(255,255,255,0.06);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 28px;
      padding: 52px 44px;
      width: 420px;
      max-width: 95vw;
      box-shadow: 0 32px 80px rgba(0,0,0,0.4);
      animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .logo-ring {
      width: 80px; height: 80px;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 28px;
      box-shadow: 0 0 40px rgba(79, 70, 229, 0.5);
    }
    .logo-ring i { font-size: 36px; color: white; }

    h1 { color: white; font-size: 26px; font-weight: 700; text-align: center; margin-bottom: 6px; }
    .subtitle { color: rgba(255,255,255,0.5); font-size: 14px; text-align: center; margin-bottom: 36px; }

    .field-label {
      display: block;
      color: rgba(255,255,255,0.7);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }

    .pin-input-wrap { position: relative; margin-bottom: 28px; }
    .pin-input {
      width: 100%;
      background: rgba(255,255,255,0.08);
      border: 1.5px solid rgba(255,255,255,0.15);
      border-radius: 14px;
      padding: 16px 52px 16px 20px;
      font-size: 22px;
      font-family: 'Outfit', sans-serif;
      color: white;
      letter-spacing: 8px;
      text-align: center;
      transition: all 0.25s;
      outline: none;
    }
    .pin-input::placeholder { color: rgba(255,255,255,0.25); letter-spacing: 2px; font-size: 14px; }
    .pin-input:focus {
      border-color: #4f46e5;
      background: rgba(79,70,229,0.12);
      box-shadow: 0 0 0 4px rgba(79,70,229,0.2);
    }

    .eye-btn {
      position: absolute; right: 16px; top: 50%;
      transform: translateY(-50%);
      background: none; border: none; cursor: pointer;
      color: rgba(255,255,255,0.4);
      font-size: 18px;
      transition: color 0.2s;
    }
    .eye-btn:hover { color: rgba(255,255,255,0.8); }

    .error-msg {
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 12px;
      padding: 12px 16px;
      color: #fca5a5;
      font-size: 13px;
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 20px;
    }

    .btn-login {
      width: 100%;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      border: none;
      border-radius: 14px;
      padding: 16px;
      color: white;
      font-size: 16px;
      font-weight: 600;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      transition: all 0.25s;
      box-shadow: 0 8px 24px rgba(79,70,229,0.4);
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(79,70,229,0.5);
    }
    .btn-login:active { transform: translateY(0); }

    .footer-text {
      text-align: center;
      color: rgba(255,255,255,0.25);
      font-size: 12px;
      margin-top: 28px;
    }
  </style>
</head>
<body>
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <div class="login-card">
    <div class="logo-ring">
      <i class="bi bi-hospital"></i>
    </div>

    <h1>Panel Médico</h1>
    <p class="subtitle">Ingresa tu PIN para acceder al sistema</p>

    <% if (error) { %>
    <div class="error-msg">
      <i class="bi bi-exclamation-circle-fill"></i>
      <%= error %>
    </div>
    <% } %>

    <form method="POST" action="/login" autocomplete="off">
      <label class="field-label" for="pin">PIN DE ACCESO</label>
      <div class="pin-input-wrap">
        <input
          type="password"
          id="pin"
          name="pin"
          class="pin-input"
          placeholder="• • • • • •"
          maxlength="8"
          autofocus
          required
        >
        <button type="button" class="eye-btn" onclick="togglePin(this)" tabindex="-1">
          <i class="bi bi-eye"></i>
        </button>
      </div>

      <button type="submit" class="btn-login" id="btn-acceder">
        <i class="bi bi-shield-lock-fill"></i>
        Acceder al Panel
      </button>
    </form>

    <p class="footer-text">Sistema de Citas Médicas · Acceso Privado</p>
  </div>

  <script>
    function togglePin(btn) {
      const input = document.getElementById('pin');
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
      } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
      }
    }

    // Shimmer en botón al enviar
    document.querySelector('form').addEventListener('submit', function() {
      const btn = document.getElementById('btn-acceder');
      btn.innerHTML = '<i class="bi bi-arrow-clockwise spin"></i> Verificando...';
      btn.disabled = true;
    });
  </script>

  <style>
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .spin { display: inline-block; animation: spin 0.8s linear infinite; }
  </style>
</body>
</html>
