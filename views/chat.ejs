<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat en Vivo - Citas Médicas</title>
    <meta name="description" content="Chat en vivo para monitorear respuestas del chatbot y comunicarse con pacientes">
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Estilos compartidos -->
    <link rel="stylesheet" href="/css/app.css">
        <style>
        /* Ajustes de diseño específicos para el Chat en Vivo */

        /* Contenedor principal de Chat */
        .chat-container {
            display: flex;
            height: calc(100vh - 120px);
            background-color: var(--surface-color);
            border-radius: var(--border-radius);
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-md);
            overflow: hidden;
        }

        /* Lista de contactos/chats */
        .chat-contacts {
            width: 320px;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            background-color: var(--surface-color);
        }

        .contacts-header {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            background-color: var(--surface-color);
        }

        .contacts-list {
            flex: 1;
            overflow-y: auto;
        }

        /* Elemento de la lista de contactos */
        .contact-item {
            display: flex;
            align-items: center;
            padding: 14px 20px;
            border-bottom: 1px solid var(--border-color);
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            position: relative;
            background-color: transparent;
        }

        .contact-item:hover {
            background-color: rgba(100, 116, 139, 0.04);
        }

        .contact-item.active {
            background-color: rgba(37, 99, 235, 0.06);
            border-left: 3px solid var(--color-primary);
        }

        [data-theme="dark"] .contact-item.active {
            background-color: rgba(255, 255, 255, 0.03);
            border-left-color: #ffffff;
        }

        .contact-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: rgba(37, 99, 235, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-primary);
            font-weight: 600;
            font-size: 1rem;
            margin-right: 12px;
            flex-shrink: 0;
        }

        [data-theme="dark"] .contact-avatar {
            background-color: rgba(255, 255, 255, 0.05);
            color: #ffffff;
        }

        .contact-info {
            flex: 1;
            min-width: 0;
        }

        .contact-name {
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 2px;
            color: var(--text-main);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .contact-last-time {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 400;
        }

        .contact-preview {
            font-size: 0.8rem;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Área activa del chat principal */
        .chat-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: var(--background-color);
        }

        .chat-main-header {
            padding: 16px 24px;
            background-color: var(--surface-color);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .chat-main-user {
            display: flex;
            align-items: center;
        }

        .chat-main-user-name {
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--text-main);
            margin-bottom: 2px;
        }

        .chat-main-user-status {
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        /* Contenedor de burbujas de chat */
        .chat-messages-scroll {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* Burbujas de mensajes */
        .msg-row {
            display: flex;
            width: 100%;
        }

        .msg-row.sent {
            justify-content: flex-end;
        }

        .msg-row.received {
            justify-content: flex-start;
        }

        .msg-bubble {
            max-width: 65%;
            padding: 10px 16px;
            border-radius: var(--border-radius);
            font-size: 0.88rem;
            line-height: 1.5;
            position: relative;
        }

        /* Burbuja recibida (Paciente) */
        .msg-row.received .msg-bubble {
            background-color: var(--surface-color);
            color: var(--text-main);
            border-top-left-radius: 2px;
            border: 1px solid var(--border-color);
        }

        /* Burbuja enviada por Doctor (Manual) */
        .msg-row.sent.doctor .msg-bubble {
            background-color: var(--color-primary);
            color: #ffffff;
            border-top-right-radius: 2px;
        }

        /* Burbuja enviada por Bot (Automático) */
        .msg-row.sent.bot .msg-bubble {
            background-color: var(--color-success);
            color: #ffffff;
            border-top-right-radius: 2px;
        }

        .msg-time {
            font-size: 0.7rem;
            margin-top: 4px;
            text-align: right;
            opacity: 0.75;
            display: block;
        }

        .msg-row.received .msg-time {
            color: var(--text-muted);
        }

        .msg-row.sent .msg-time {
            color: rgba(255, 255, 255, 0.9);
        }

        .msg-tag {
            font-size: 0.62rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 700;
            display: block;
            margin-bottom: 2px;
            opacity: 0.85;
        }

        /* Área de escritura inferior */
        .chat-input-area {
            padding: 16px 24px;
            background-color: var(--surface-color);
            border-top: 1px solid var(--border-color);
        }

        .chat-form {
            display: flex;
            gap: 12px;
        }

        .chat-input {
            flex: 1;
            border: 1px solid var(--border-color);
            border-radius: var(--border-radius);
            padding: 10px 16px;
            font-size: 0.88rem;
            transition: all 0.2s ease-in-out;
            resize: none;
            height: 42px;
            line-height: 20px;
            background-color: var(--surface-color);
            color: var(--text-main);
        }

        .chat-input:focus {
            outline: none;
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }

        [data-theme="dark"] .chat-input:focus {
            border-color: #ffffff;
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.1);
        }

        .chat-send-btn {
            width: 42px;
            height: 42px;
            border-radius: var(--border-radius);
            background-color: var(--color-primary);
            color: #ffffff;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease-in-out;
        }

        .chat-send-btn:hover {
            background-color: #1d4ed8;
        }

        [data-theme="dark"] .chat-send-btn {
            background-color: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #ffffff;
        }

        [data-theme="dark"] .chat-send-btn:hover {
            background-color: rgba(255, 255, 255, 0.15);
        }

        .chat-empty-state {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            padding: 40px;
        }

        .chat-empty-icon {
            font-size: 3.5rem;
            margin-bottom: 12px;
            color: var(--border-color);
        }

        /* Pulsing Dot for Live Chat */
        .nav-link .badge-dot {
            background: #f43f5e;
            border-radius: 50%;
            width: 8px;
            height: 8px;
            margin-left: auto;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: .5; transform: scale(1.3); }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar Navigation -->
            <div class="col-md-2 sidebar p-0 d-flex flex-column d-none d-md-flex">
                <div class="p-4 brand-title d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-hospital fs-4" style="color:#818cf8"></i>
                    <span class="fs-5">Citas Médicas</span>
                </div>
                <nav class="nav flex-column">
                    <a class="nav-link" href="/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                    <a class="nav-link" href="/citas"><i class="bi bi-calendar3"></i> Citas</a>
                    <a class="nav-link" href="/pacientes"><i class="bi bi-people-fill"></i> Pacientes</a>
                    <a class="nav-link" href="/mensajes"><i class="bi bi-chat-left-dots-fill"></i> Mensajes</a>
                    <a class="nav-link active" href="/chat"><i class="bi bi-chat-dots-fill"></i> Chat en Vivo <span class="badge-dot" id="unread-dot" style="display:none"></span></a>
                    <a class="nav-link" href="/analytics"><i class="bi bi-bar-chart-line-fill"></i> Analytics</a>
                    <a class="nav-link" href="/configuracion"><i class="bi bi-gear-fill"></i> Configuración</a>
                </nav>

                <!-- WhatsApp Status Widget -->
                <div class="wa-status-widget mx-2 mt-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="wa-dot off" id="ws-status-icon"></span>
                        <span class="fw-semibold small text-main">WhatsApp Bot</span>
                    </div>
                    <div id="ws-status-text" class="small text-muted">Consultando...</div>
                    <div id="ws-qr-container" class="mt-2 text-center d-none">
                        <img id="ws-qr-img" src="" alt="Escanee QR" class="img-fluid rounded" style="max-height:120px">
                        <div class="small mt-1 text-warning">📱 Escanee para conectar</div>
                    </div>
                    <button onclick="reconectarWA()" class="btn btn-sm w-100 mt-2">
                        <i class="bi bi-arrow-repeat me-1"></i>Reconectar
                    </button>
                </div>

                <div class="px-3 py-2 mt-auto mb-2">
                    <button class="btn-sidebar-action mb-2 animate-hover" onclick="toggleDark()">
                        <i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro
                    </button>
                    <a href="/logout" class="btn-sidebar-action btn-sidebar-danger animate-hover">
                        <i class="bi bi-box-arrow-left"></i> Cerrar Sesión
                    </a>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="col-md-10 main-content">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                    <div>
                        <h2 class="fw-bold mb-1">💬 Chat en Vivo</h2>
                        <p class="text-muted mb-0">Monitorea las respuestas del chatbot virtual y responde manualmente a tus pacientes por WhatsApp</p>
                    </div>
                </div>

                <!-- Chat layout wrapper -->
                <div class="chat-container">
                    <!-- Left: Contacts Sidebar -->
                    <div class="chat-contacts">
                        <div class="contacts-header">
                            <div class="input-group">
                                <span class="input-group-text bg-body-tertiary border-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" class="form-control bg-body-tertiary border-0" id="search-contacts" placeholder="Buscar paciente..." style="border-radius: 0 var(--border-radius) var(--border-radius) 0;">
                            </div>
                        </div>
                        <div class="contacts-list" id="contacts-list-container">
                            <% if (pacientes.length === 0) { %>
                                <div class="p-4 text-center text-muted">No hay pacientes registrados</div>
                            <% } else { %>
                                <% pacientes.forEach(p => { %>
                                    <div class="contact-item" data-phone="<%= p.telefono %>" data-name="<%= p.nombre %>" onclick="selectContact(this)">
                                        <div class="contact-avatar">
                                            <%= p.nombre ? p.nombre.charAt(0).toUpperCase() : 'P' %>
                                        </div>
                                        <div class="contact-info">
                                            <div class="contact-name">
                                                <span><%= p.nombre %></span>
                                                <div class="d-flex align-items-center gap-2">
                                                    <% if (p.no_leidos > 0) { %>
                                                        <span class="badge bg-success rounded-pill" id="badge-<%= p.telefono %>" style="font-size:0.7rem; padding: 4px 8px;"><%= p.no_leidos %></span>
                                                    <% } else { %>
                                                        <span class="badge bg-success rounded-pill d-none" id="badge-<%= p.telefono %>" style="font-size:0.7rem; padding: 4px 8px;">0</span>
                                                    <% } %>
                                                    <span class="contact-last-time" id="time-<%= p.telefono %>">
                                                        <%= p.ultimo_mensaje_en ? new Date(p.ultimo_mensaje_en).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : '' %>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="contact-preview" id="preview-<%= p.telefono %>">
                                                <%= p.ultimo_mensaje || 'Sin mensajes registrados' %>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } %>
                        </div>
                    </div>

                    <!-- Right: Message window -->
                    <div class="chat-main" id="chat-main-window">
                        <div class="chat-empty-state" id="empty-state-view">
                            <i class="bi bi-chat-left-text chat-empty-icon"></i>
                            <h5 class="fw-bold">Selecciona un Paciente</h5>
                            <p class="mb-0 text-center">Elige un paciente del panel izquierdo para ver el historial y enviarle mensajes.</p>
                        </div>

                        <!-- Active Chat view (Hidden by default) -->
                        <div class="d-none flex-column h-100" id="active-chat-view">
                            <div class="chat-main-header">
                                <div class="chat-main-user">
                                    <div class="contact-avatar" id="active-avatar-icon">P</div>
                                    <div>
                                        <div class="chat-main-user-name" id="active-user-name">Nombre de Paciente</div>
                                        <div class="chat-main-user-status" id="active-user-phone">Teléfono</div>
                                    </div>
                                </div>
                                <div>
                                    <button class="btn btn-outline-secondary btn-sm" onclick="reloadActiveChat()"><i class="bi bi-arrow-clockwise"></i> Actualizar</button>
                                </div>
                            </div>

                            <!-- Messages Area -->
                            <div class="chat-messages-scroll" id="chat-messages-scroll">
                                <!-- Messages will be dynamically rendered here -->
                            </div>

                            <!-- Input Area -->
                            <div class="chat-input-area">
                                <form class="chat-form" onsubmit="sendMessage(event)">
                                    <input type="text" class="chat-input" id="message-text-input" placeholder="Escribe un mensaje..." required autocomplete="off">
                                    <button type="submit" class="chat-send-btn"><i class="bi bi-send-fill"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let selectedPhone = null;

        // Búsqueda de contactos
        document.getElementById('search-contacts').addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase().trim();
            const contacts = document.querySelectorAll('.contact-item');
            contacts.forEach(c => {
                const name = c.dataset.name.toLowerCase();
                const phone = c.dataset.phone;
                if (name.includes(query) || phone.includes(query)) {
                    c.classList.remove('d-none');
                } else {
                    c.classList.add('d-none');
                }
            });
        });

        async function selectContact(element) {
            // Activar clase
            document.querySelectorAll('.contact-item').forEach(c => c.classList.remove('active'));
            element.classList.add('active');

            selectedPhone = element.dataset.phone;
            const name = element.dataset.name;

            // Cambiar vistas
            document.getElementById('empty-state-view').classList.add('d-none');
            document.getElementById('active-chat-view').classList.remove('d-none');
            document.getElementById('active-chat-view').classList.add('d-flex');

            document.getElementById('active-user-name').innerText = name;
            document.getElementById('active-user-phone').innerText = '+' + selectedPhone;
            document.getElementById('active-avatar-icon').innerText = name.charAt(0).toUpperCase();

            // Limpiar badge local
            const contactBadge = document.getElementById(`badge-${selectedPhone}`);
            if (contactBadge) {
                contactBadge.classList.add('d-none');
                contactBadge.innerText = '0';
            }

            await loadHistory(selectedPhone);
            await loadUnreadCount();
        }

        async function loadHistory(phone) {
            try {
                const response = await fetch(`/chat/historial/${phone}`);
                const messages = await response.json();
                const container = document.getElementById('chat-messages-scroll');
                container.innerHTML = '';

                if (messages.length === 0) {
                    container.innerHTML = '<div class="text-center text-muted my-4">No hay mensajes previos en este chat</div>';
                } else {
                    messages.forEach(msg => {
                        appendMessageBubble(msg.remitente, msg.mensaje, msg.creado_en);
                    });
                }
                scrollToBottom();
            } catch (error) {
                console.error('Error cargando historial:', error);
            }
        }

        function appendMessageBubble(remitente, mensaje, creado_en) {
            const container = document.getElementById('chat-messages-scroll');
            const row = document.createElement('div');
            
            const isSent = remitente === 'doctor' || remitente === 'bot';
            row.className = `msg-row ${isSent ? 'sent' : 'received'} ${remitente}`;

            const timeStr = new Date(creado_en).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});

            let tag = '';
            if (remitente === 'bot') tag = '<span class="msg-tag">🤖 Asistente Virtual</span>';
            if (remitente === 'doctor') tag = '<span class="msg-tag">👨‍⚕️ Médico</span>';

            row.innerHTML = `
                <div class="msg-bubble">
                    ${tag}
                    <div>${mensaje}</div>
                    <span class="msg-time">${timeStr}</span>
                </div>
            `;
            container.appendChild(row);
        }

        async function reloadActiveChat() {
            if (selectedPhone) {
                await loadHistory(selectedPhone);
            }
        }

        async function sendMessage(e) {
            e.preventDefault();
            const input = document.getElementById('message-text-input');
            const text = input.value.trim();
            if (!text || !selectedPhone) return;

            input.value = '';

            try {
                const response = await fetch('/chat/enviar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ telefono: selectedPhone, mensaje: text })
                });
                const data = await response.json();
                if (!data.success) {
                    alert('Error enviando mensaje: ' + (data.error || 'Intenta de nuevo'));
                }
                // El mensaje se actualizará automáticamente mediante el stream SSE
            } catch (error) {
                console.error('Error enviando mensaje:', error);
            }
        }

        function scrollToBottom() {
            const container = document.getElementById('chat-messages-scroll');
            container.scrollTop = container.scrollHeight;
        }

        async function reconectarWA() {
            try {
                await fetch('/api/whatsapp/reconectar', { method: 'POST' });
            } catch (e) {}
        }

        // Dark Mode Toggle
        function toggleDark() {
            const html = document.documentElement;
            const isDark = html.getAttribute('data-theme') === 'dark';
            const nextTheme = isDark ? '' : 'dark';
            html.setAttribute('data-theme', nextTheme);
            html.setAttribute('data-bs-theme', nextTheme === 'dark' ? 'dark' : 'light');
            
            const icon = document.getElementById('dark-icon');
            if (icon) {
                icon.className = isDark ? 'bi bi-moon-fill' : 'bi bi-sun-fill';
                const parent = icon.parentElement;
                if (parent) {
                    parent.innerHTML = isDark
                        ? '<i class="bi bi-moon-fill" id="dark-icon"></i> Modo Oscuro'
                        : '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
                }
            }
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
        }
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.setAttribute('data-bs-theme', 'dark');
            document.addEventListener('DOMContentLoaded', () => {
                const icon = document.getElementById('dark-icon');
                if (icon) {
                    icon.className = 'bi bi-sun-fill';
                    const parent = icon.parentElement;
                    if (parent) {
                        parent.innerHTML = '<i class="bi bi-sun-fill" id="dark-icon"></i> Modo Claro';
                    }
                }
            });
        }

        // Fetch unread chat count
        async function loadUnreadCount() {
            try {
                const res = await fetch('/api/chat/no-leidos');
                const data = await res.json();
                const dot = document.getElementById('unread-dot');
                if (dot) {
                    dot.style.display = data.count > 0 ? 'inline-block' : 'none';
                }
            } catch (err) { console.error('Error fetching unread count:', err); }
        }
        loadUnreadCount();

        // Abrir chat automático desde query parameter (?phone=...) o (?telefono=...)
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const phoneParam = urlParams.get('phone') || urlParams.get('telefono');
            if (phoneParam) {
                const cleanPhone = phoneParam.replace(/\D/g, '');
                setTimeout(() => {
                    const contactEl = document.querySelector(`.contact-item[data-phone="${cleanPhone}"]`);
                    if (contactEl) {
                        selectContact(contactEl);
                    }
                }, 300);
            }
        });

        // Conectar al Server-Sent Events (SSE) para actualizaciones en tiempo real
        const liveUpdates = new EventSource('/api/updates/live');
        
        liveUpdates.addEventListener('wa_status', e => {
            const d = JSON.parse(e.data);
            const dot = document.getElementById('ws-status-icon');
            const text = document.getElementById('ws-status-text');
            const qrContainer = document.getElementById('ws-qr-container');
            const qrImg = document.getElementById('ws-qr-img');
            
            if (dot && text) {
                if (d.status === 'conectado') {
                    dot.className = 'bi bi-circle-fill text-success';
                    text.innerText = 'Conectado (Listo)';
                    if (qrContainer) qrContainer.classList.add('d-none');
                } else {
                    dot.className = 'bi bi-circle-fill text-danger';
                    text.innerText = `Desconectado (${d.status})`;
                    if ((d.qr || d.qrCode) && qrContainer) {
                        qrImg.src = d.qr || d.qrCode;
                        qrContainer.classList.remove('d-none');
                    } else if (qrContainer) {
                        qrContainer.classList.add('d-none');
                    }
                }
            }
        });

        liveUpdates.addEventListener('mensaje', function(e) {
            const data = JSON.parse(e.data);
            const phone = data.telefono;
            const text = data.texto;
            const remitente = data.remitente;
            const fecha = data.fecha;

            // Actualizar vista lateral de preview
            const previewEl = document.getElementById(`preview-${phone}`);
            const timeEl = document.getElementById(`time-${phone}`);
            if (previewEl) {
                previewEl.innerText = text;
                previewEl.style.fontWeight = 'bold';
            }
            if (timeEl) {
                timeEl.innerText = new Date(fecha).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            }

            // Mover el contacto al principio de la lista lateral
            const contactsContainer = document.getElementById('contacts-list-container');
            const contactItem = document.querySelector(`.contact-item[data-phone="${phone}"]`);
            if (contactItem && contactsContainer) {
                contactsContainer.prepend(contactItem);
            }

            // Si es el contacto abierto, append la burbuja
            if (selectedPhone === phone) {
                const noMsgTxt = document.querySelector('#chat-messages-scroll .text-center');
                if (noMsgTxt) noMsgTxt.remove();
                
                appendMessageBubble(remitente, text, fecha);
                scrollToBottom();
            }

            // Si el mensaje es recibido de paciente y no es el chat seleccionado, actualizar unread dot y badge local
            if (remitente === 'paciente') {
                if (selectedPhone !== phone) {
                    const dot = document.getElementById('unread-dot');
                    if (dot) dot.style.display = 'inline-block';

                    const contactBadge = document.getElementById(`badge-${phone}`);
                    if (contactBadge) {
                        let count = parseInt(contactBadge.innerText || '0');
                        count += 1;
                        contactBadge.innerText = count;
                        contactBadge.classList.remove('d-none');
                    }
                } else {
                    // Si es el chat activo, marcar como leídos en la base de datos de inmediato
                    fetch(`/chat/historial/${phone}`).then(() => loadUnreadCount());
                }
            }
        });

        window.addEventListener('beforeunload', () => {
            if (liveUpdates) liveUpdates.close();
        });
    </script>
</body>
</html>
